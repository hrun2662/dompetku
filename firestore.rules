rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Safety Net: Deny read/write by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Transactions Security Rules
    match /transactions/{transactionId} {
      // Allow reading and listing if authenticated and the resource belongs to the user
      allow read: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      
      // Allow creation if authenticated and client's provided userId matches auth uid
      allow create: if request.auth != null 
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.id != null
        && request.resource.data.type in ['income', 'expense']
        && request.resource.data.amount > 0;
        
      // Allow update if authenticated and client is the owner of the document
      allow update: if request.auth != null 
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
        
      // Allow delete if authenticated and client is the owner
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
