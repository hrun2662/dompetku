rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Safety Net: Deny read/write by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['id', 'userId', 'type', 'category', 'amount', 'date', 'createdAt', 'updatedAt'])
        && data.keys().size() >= 8 && data.keys().size() <= 11
        && data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId == request.auth.uid
        && data.type is string && (data.type == 'income' || data.type == 'expense')
        && data.category is string && data.category.size() <= 64
        && (data.amount is int || data.amount is float) && data.amount > 0
        && data.date is string && data.date.matches('^\\d{4}-\\d{2}-\\d{2}$')
        && (!data.keys().hasAll(['description']) || (data.description is string && data.description.size() <= 200))
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    // Transactions Security Rules
    match /transactions/{transactionId} {
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && existing().userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(transactionId)
        && isValidTransaction(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
        
      allow update: if isSignedIn()
        && isValidId(transactionId)
        && isOwner(existing().userId)
        && isValidTransaction(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time;
        
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }
  }
}
